# Morning Audio Brief — local development environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Gemini API key — from aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# FRED API key — free from fred.stlouisfed.org/docs/api/api_key.html
# Enables bond market indicators: IG/HY OAS, treasury yields, yield curve
# Optional — pipeline runs without it but market data segment will be thin
FRED_API_KEY=your_fred_api_key_here

# Google Cloud TTS — path to your downloaded service account JSON key
GOOGLE_APPLICATION_CREDENTIALS=./tts-service-account.json

# Gmail — daily script archive
# Sends the synthesized script as a formatted HTML email to the dedicated project account
# Both sender and recipient are the same dedicated Gmail account
# App password: myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_ADDRESS=your.dedicated.project.account@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# GitHub Pages base URL for your repo
# Format: https://[yourusername].github.io/morning-brief
GITHUB_PAGES_BASE_URL=https://yourusername.github.io/morning-brief
